# ============================================================
# TP DAN 2026 — Variables de Entorno
# Copiar este archivo como .env y completar los valores.
# NUNCA commitear .env con valores reales.
# ============================================================

# ------------------------------------------------------------
# PostgreSQL — usuario administrador de la base de datos
# ------------------------------------------------------------
POSTGRES_PASSWORD=cambiar_en_produccion

# Usuario exclusivo para auth-service (solo accede al schema "auth")
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=cambiar_en_produccion

# Usuario exclusivo para transaction-service (solo accede al schema "txn")
TXN_DB_USER=txn_user
TXN_DB_PASSWORD=cambiar_en_produccion

# Usuario exclusivo para ai-service (solo accede al schema "ai" — RAG/pgvector)
AI_DB_USER=ai_db_user
AI_DB_PASSWORD=cambiar_en_produccion

# ------------------------------------------------------------
# MongoDB — base de datos del ai-service
# ------------------------------------------------------------
# Usuario root (solo para crear el db user de aplicación)
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=cambiar_en_produccion

# Usuario de aplicación: ai-service se conecta con este
MONGO_APP_USER=ai_user
MONGO_APP_PASSWORD=cambiar_en_produccion

# ------------------------------------------------------------
# RabbitMQ — mensajería asincrónica
# Management UI disponible en http://localhost:15672
# ------------------------------------------------------------
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=cambiar_en_produccion

# ------------------------------------------------------------
# JWT — clave secreta compartida entre auth-service y api-gateway
# Generar con: openssl rand -hex 64
# Mínimo 64 caracteres para HS512
# ------------------------------------------------------------
JWT_SECRET=reemplazar_con_clave_generada_de_minimo_64_caracteres_hex

# ------------------------------------------------------------
# INTERNAL API — secreto compartido entre auth-service y ai-service
# para el endpoint interno que resuelve API keys descifradas (no pasa por el gateway)
# Generar con: openssl rand -hex 32
# ------------------------------------------------------------
INTERNAL_API_SECRET=reemplazar_con_clave_generada_de_32_caracteres_hex

# ------------------------------------------------------------
# MinIO — almacenamiento de comprobantes (receipts)
# Console UI disponible en http://localhost:9001
# ------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=cambiar_en_produccion

# ------------------------------------------------------------
# Grafana — dashboards de métricas
# UI disponible en http://localhost:3000
# ------------------------------------------------------------
GRAFANA_PASSWORD=admin

# ------------------------------------------------------------
# AI Service — claves de proveedores de IA (server-side)
# El frontend NO maneja estas claves en Fase B+.
# Configurar al menos una según el proveedor elegido.
# ------------------------------------------------------------
AI_PROVIDER=claude
CLAUDE_API_KEY=sk-ant-tu-clave-aqui
# esta configurado como fallback para los embeddings de OpenAI
OPENAI_API_KEY=sk-tu-clave-aqui
GEMINI_API_KEY=AIza-tu-clave-aqui

# ------------------------------------------------------------
# OAuth2 — Google
# Crear en: https://console.developers.google.com
# Authorized redirect URIs: http://localhost:8080/login/oauth2/code/google
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-secret

# ------------------------------------------------------------
# OAuth2 — GitHub
# Crear en: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:8080/login/oauth2/code/github
# ------------------------------------------------------------
GITHUB_CLIENT_ID=Ov23li-tu-client-id
GITHUB_CLIENT_SECRET=tu-github-secret

# URL base del API Gateway tal como la ve el browser (para redirect_uri en OAuth2)
OAUTH2_REDIRECT_BASE_URL=http://localhost:8080

# URL del frontend tal como la ve el browser (para redirigir tras OAuth2 exitoso)
APP_FRONTEND_URL=http://localhost:3001

# ------------------------------------------------------------
# Mail — Verificacion de email
# En desarrollo usar Mailhog (UI: http://localhost:8025)
# En produccion configurar SMTP real (Gmail, SendGrid, etc.)
# ------------------------------------------------------------
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=noreply@pesito.app
# Para SMTP autenticado (produccion):
# MAIL_USERNAME=tu-usuario
# MAIL_PASSWORD=tu-clave
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_TLS=true
