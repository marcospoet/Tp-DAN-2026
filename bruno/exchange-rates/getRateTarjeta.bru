meta {
  name: getRateTarjeta
  type: http
  seq: 4
}

get {
  url: http://localhost:8082/api/rates/tarjeta
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

assert {
  res.status: eq 200
  res.body.type: eq tarjeta
}

script:post-response {
  const r = res.body;
  test("buyPrice es mayor a 0", function() {
    expect(r.buyPrice).to.be.greaterThan(0);
  });
  test("sellPrice es mayor a 0", function() {
    expect(r.sellPrice).to.be.greaterThan(0);
  });
  bru.setEnvVar("tarjetaRate", r.sellPrice);
}

settings {
  encodeUrl: false
  timeout: 8000
}
