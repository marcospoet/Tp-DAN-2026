meta {
  name: consultarDolarBlue
  type: http
  seq: 2
}

get {
  url: https://dolarapi.com/v1/dolares/blue
  body: none
  auth: inherit
}

assert {
  res.status: eq 200
  res.body.casa: eq blue
}

script:post-response {
  const r = res.body;
  test("tiene precio de compra", function() {
    expect(r.compra).to.be.greaterThan(0);
  });
  test("tiene precio de venta", function() {
    expect(r.venta).to.be.greaterThan(0);
  });
  test("tiene fechaActualizacion", function() {
    expect(r).to.have.property("fechaActualizacion");
  });
}

settings {
  encodeUrl: true
  timeout: 5000
}
