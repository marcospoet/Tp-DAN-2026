meta {
  name: register
  type: http
  seq: 1
}

post {
  url: http://localhost:8081/api/auth/register
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}",
    "userName": "Test User"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("token", res.body.token);
    bru.setEnvVar("userId", res.body.userId);
  }
}

settings {
  encodeUrl: false
}
