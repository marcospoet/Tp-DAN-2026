meta {
  name: login
  type: http
  seq: 2
}

post {
  url: http://localhost:8081/api/auth/login
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.token);
    bru.setEnvVar("userId", res.body.userId);
  }
}

settings {
  encodeUrl: false
}
