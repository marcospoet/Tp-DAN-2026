meta {
  name: actualizarTxn
  type: http
  seq: 7
}

put {
  url: http://localhost:8082/api/transactions/{{txnId}}
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  X-User-Id: {{userId}}
  Authorization: Bearer {{token}}
}

body:json {
  {
    "description": "Supermercado Carrefour",
    "amount": 18000.00
  }
}

settings {
  encodeUrl: false
  timeout: 5000
}
