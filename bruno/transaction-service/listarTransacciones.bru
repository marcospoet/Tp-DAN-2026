meta {
  name: listarTransacciones
  type: http
  seq: 4
}

get {
  url: http://localhost:8082/api/transactions
  body: none
  auth: inherit
}

params:query {
  page: 0
  size: 10
  sort: date,desc
}

headers {
  X-User-Id: {{userId}}
  Authorization: Bearer {{token}}
}

settings {
  encodeUrl: false
}
