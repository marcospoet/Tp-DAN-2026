meta {
  name: listarFiltroFechas
  type: http
  seq: 5
}

get {
  url: http://localhost:8082/api/transactions
  body: none
  auth: inherit
}

params:query {
  from: 2026-04-01
  to: 2026-04-30
  page: 0
  size: 10
}

headers {
  X-User-Id: {{userId}}
  Authorization: Bearer {{token}}
}

settings {
  encodeUrl: false
  timeout: 5000
}
